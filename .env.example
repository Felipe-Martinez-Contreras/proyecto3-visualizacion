# Copia este archivo a `.env` y ajusta los valores. `.env` está en .gitignore.
# Estas variables son las PREVISTAS; se irán usando a medida que se implemente.

# --- Base de datos ---
# Ruta al archivo SQLite compartido (versionado en el repo).
DB_PATH=db/monitoreo.sqlite

# --- Ingesta / simulador ---
# Intervalo (segundos) entre ticks del scheduler de ingesta (ingesta/scheduler.py).
# El enunciado pide 5-30 s; por defecto 10.
INTERVALO_SIMULACION=10

# --- APIs externas (base URLs; sin claves reales aquí) ---
# Clima: Open-Meteo (no requiere API key).
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1
# Calidad del aire (por defecto): Open-Meteo Air Quality (GRATIS, sin key).
OPENMETEO_AIRE_BASE_URL=https://air-quality-api.open-meteo.com/v1
# Calidad del aire (fallback/opción): OpenAQ.
OPENAQ_BASE_URL=https://api.openaq.org/v3
# Clave de OpenAQ (requerida por la API v3, se envía en el header X-API-Key).
# NO poner el valor real en este archivo; ponlo en tu `.env` local (está en .gitignore).
OPENAQ_API_KEY=

# --- Fuente de calidad del aire ---
# Fuente primaria: "open-meteo" (por defecto, sin key) u "openaq" (requiere key).
# Si la primaria falla (red/config), se intenta la otra como fallback automático.
FUENTE_AIRE=open-meteo

# --- Ubicaciones por zona ---
# Clima: coordenadas GLOBALES de la ciudad (ej. Santiago). Open-Meteo se consulta
# con una sola coordenada porque el clima no se desagrega por zona.
CLIMA_LATITUD=-33.45
CLIMA_LONGITUD=-70.66
# Calidad del aire con Open-Meteo AQ: coordenadas por zona (Centro/Norte/Sur).
# OJO: la grilla de Open-Meteo AQ es de ~0.1°; las zonas deben separarse ≥0.15°
# en latitud para caer en celdas distintas (si no, la API devuelve valores idénticos).
# Defaults en el código: Centro = Santiago centro, Norte = Colina/Quilicura,
# Sur = Puente Alto/Pirque. Ajústalas si hace falta, manteniendo la separación.
AIRE_LAT_CENTRO=-33.45
AIRE_LON_CENTRO=-70.66
AIRE_LAT_NORTE=-33.20
AIRE_LON_NORTE=-70.68
AIRE_LAT_SUR=-33.61
AIRE_LON_SUR=-70.58
# Calidad del aire con OpenAQ (fallback): id de ubicación por zona (Centro/Norte/Sur).
# Rellenar con los IDs reales de las estaciones elegidas en OpenAQ.
OPENAQ_LOC_CENTRO=
OPENAQ_LOC_NORTE=
OPENAQ_LOC_SUR=

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8050
# Segundos entre refrescos en vivo del dashboard (dcc.Interval).
DASHBOARD_INTERVALO_REFRESCO=5
# La ventana de tiempo mostrada ya no es fija: se elige en la UI con el filtro
# "Rango de tiempo" (últimos 5 min / 1 hora / día).
